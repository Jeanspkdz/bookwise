{
  "name": "bookwise",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "auth:generate": "pnx auth@latest generate --config ./layers/auth/server/utils/auth.ts --output ./layers/shared/server/db/schema/auth.schema.ts",
    "db:generate": "drizzle-kit generate --config=layers/shared/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=layers/shared/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=layers/shared/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=layers/shared/drizzle.config.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.6.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pinia/nuxt": "0.11.3",
    "@tanstack/vue-table": "^8.21.3",
    "better-auth": "^1.6.10",
    "drizzle-orm": "1.0.0-beta.22",
    "nuxt": "^4.4.2",
    "nuxt-uploadthing": "1.2.4",
    "pinia": "^3.0.4",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.2.2",
    "uploadthing": "^7.7.4",
    "vidstack": "^1.12.13",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "1.0.0-beta.22",
    "eslint": "^10.3.0",
    "eslint-plugin-nuxt-layers": "^0.2.0",
    "eslint-plugin-oxlint": "^1.58.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
